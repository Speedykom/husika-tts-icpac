# HUSIKA TTS — Environment Configuration
# Copy to .env and adjust as needed.

TTS_API_HOST=0.0.0.0
TTS_API_PORT=8000
LOG_LEVEL=info

# JWT signing secret for /auth/login tokens. Override before deploying.
JWT_SECRET=change-before-deploying

# HuggingFace access token — required to pull any private/gated models at
# runtime. Public models work without it. Create one at
# https://huggingface.co/settings/tokens
HF_TOKEN=

# Custom fine-tuned model repos, injected at runtime so repo ids stay out of
# the source tree. Both are JSON objects mapping a language code to a repo id.
# MMS_MODEL_OVERRIDES overrides the public facebook/mms-tts defaults; COQUI_MODELS
# registers Coqui-format VITS repos. Leave empty to run with public models only.
#   MMS_MODEL_OVERRIDES={"xyz": "your-org/mms-tts-xyz"}
#   COQUI_MODELS={"xyz": "your-org/xyz-tts-vits"}
MMS_MODEL_OVERRIDES=
COQUI_MODELS=

# API key for external consumers of the TTS API (X-API-Key header)
# generate one with: python scripts/generate_api_key.py
API_KEY=
