# HUSIKA TTS — Production env template
# On the VPS, copy this file to /srv/husika/.env and edit values as needed.
# docker compose reads .env from the same dir as docker-compose.yml.

# Container image to run. CI/CD writes the latest commit SHA tag here on each
# successful deploy; :latest is the fallback for manual `docker compose up`.
IMAGE=ghcr.io/speedykom/husika-tts:latest

# Application log level (debug | info | warning | error)
LOG_LEVEL=info

# Path to the SQLite database inside the app container. The backup/restore
# scripts read this same value, so the DB location is defined in one place.
DB_PATH=/app/data/husika.db

# Name of the app container (Compose project "husika" -> husika-app-1). Used by
# the backup/restore scripts to exec into the running app.
CONTAINER=husika-app-1

# How many days of database backups to keep; older ones are pruned by backup.sh.
BACKUP_KEEP_DAYS=7
