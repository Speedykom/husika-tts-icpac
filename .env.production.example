# HUSIKA TTS — Production env template
# On the VPS, copy this file to /srv/husika/.env and edit values as needed.
# docker compose reads .env from the same dir as docker-compose.yml.

# Container image to run. CI/CD writes the latest commit SHA tag here on each
# successful deploy; :latest is the fallback for manual `docker compose up`.
IMAGE=ghcr.io/speedykom/husika-tts:latest

# Application log level (debug | info | warning | error)
LOG_LEVEL=info
